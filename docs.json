{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Meradomo",
  "description": "Build apps that run on a user's own computer and reach them from anywhere, through Meradomo.",
  "colors": {
    "primary": "#2199B5",
    "light": "#5EC3D7",
    "dark": "#0A6F88"
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "favicon": "/logo/light.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get started",
            "pages": [
              "introduction",
              "quickstart"
            ]
          },
          {
            "group": "Guides",
            "pages": [
              "guides/agent-api",
              "guides/embedded-engine",
              "guides/oauth",
              "guides/security-model",
              "guides/threat-model",
              "guides/custom-domain"
            ]
          },
          {
            "group": "Examples",
            "pages": [
              "examples/fridge-notes",
              "examples/remote-notes-client"
            ]
          }
        ]
      },
      {
        "tab": "API reference",
        "groups": [
          {
            "group": "API reference",
            "pages": [
              "api-reference/introduction"
            ]
          },
          {
            "group": "Endpoints",
            "openapi": "/api-reference/openapi.json"
          }
        ]
      }
    ]
  },
  "navbar": {
    "links": [
      {
        "label": "Apps",
        "href": "https://meradomo.com/apps"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get Meradomo",
      "href": "https://meradomo.com"
    }
  },
  "footer": {
    "socials": {
      "website": "https://meradomo.com"
    }
  },
  "background": {
    "color": {
      "light": "#FAF9F7",
      "dark": "#0a0a0c"
    }
  },
  "fonts": {
    "family": "Inter"
  },
  "appearance": {
    "default": "dark"
  },
  "styling": {
    "eyebrows": "breadcrumbs"
  }
}
